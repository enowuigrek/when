# Copy this file to .env.local and fill in all values.
# In Vercel: add these as Environment Variables in project settings.

# --- Supabase ---
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# --- Owner panel ---
# Password for /admin login. Change before going live.
ADMIN_PASSWORD=change_me_before_deploy
# Random 64-char hex string. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate_with_crypto_randomBytes_32

# --- Resend emails ---
# Get API key from resend.com → API Keys
RESEND_API_KEY=re_...
# Must match a verified sending domain in Resend.
# For local testing without domain: leave empty (emails will be skipped).
RESEND_FROM=when? <rezerwacje@yourdomain.pl>
